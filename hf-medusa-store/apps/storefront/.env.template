# ─────────────────────────────────────────────────────────────
# hf-medusa-store — storefront env template
# Copy to `.env.local` (gitignored) and fill in the publishable key.
# Storefront runs on port 8008 (see package.json dev/start scripts).
# ─────────────────────────────────────────────────────────────

# Publishable API key from the backend.
# Get it in Admin (http://localhost:9009/app) → Settings → Publishable API Keys,
# or reuse the one seeded by `medusa db:migrate`.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_

# Backend API — hf backend runs on 9009
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9009

# Default region seeded by the backend
NEXT_PUBLIC_DEFAULT_REGION=dk

# Storefront base URL (this app runs on 8008)
NEXT_PUBLIC_BASE_URL=http://localhost:8008

# Optional integrations
NEXT_PUBLIC_STRIPE_KEY=
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

NODE_ENV=development
